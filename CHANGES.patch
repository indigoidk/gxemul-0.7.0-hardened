+			while (*s == ' ')
+				s ++;
+			/*  Split at this space, unless it is adjacent to an
+			    operator (or leads/ends the string):  */
+			if (*s != '\0' && prevch != '\0' &&
+			    strchr(operators, *s) == NULL &&
+			    strchr(operators, prevch) == NULL)
+				return space;
+		} else {
+			prevch = *s;
+			s ++;
+		}
+	}
