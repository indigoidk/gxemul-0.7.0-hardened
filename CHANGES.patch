+/*
+ *  #258:  FCSR decoded: fcc byte (bit 23 = FCC0, bits 31..25 = FCC7..1),
+ *  FS (flush-to-zero), cause/enables/flags groups (E=unimpl, V=invalid,
+ *  Z=div0, O=overflow, U=underflow, I=inexact; only cause has E), and RM.
+ */
+static void mips_cpu_dump_fcsr(struct cpu *cpu, uint32_t f)
+{
+	static const char *rmnames[4] = { "RN", "RZ", "RP", "RM" };
+	static const char letters[] = "EVZOUI";
+	char causes[7], enab[6], flags[6];
+	int j;
+
+	for (j=0; j<6; j++)
+		causes[j] = f & (MIPS_FPU_EXCEPTION_INEXACT << (5-j))?
+		    letters[j] : '-';
+	for (j=0; j<5; j++) {
+		enab[j] = f & (MIPS_FPU_ENABLE_INEXACT << (4-j))?
+		    letters[j+1] : '-';
+		flags[j] = f & (MIPS_FPU_STICKY_INEXACT << (4-j))?
+		    letters[j+1] : '-';
+	}
+	causes[6] = enab[5] = flags[5] = '\0';
+
+	debug("cpu%i:   fcsr:  fcc=0x%02x%s cause=%s enables=%s flags=%s"
+	    " rm=%s\n", cpu->cpu_id,
+	    (int) (((f >> MIPS_FCSR_FCC0_SHIFT) & 1) |
+	    ((f >> (MIPS_FCSR_FCC1_SHIFT - 1)) & 0xfe)),
+	    f & MIPS_FPU_FLUSH_BIT? " fs" : "",
+	    causes, enab, flags, rmnames[f & MIPS_FPU_ROUNDING_BITS]);
+}
