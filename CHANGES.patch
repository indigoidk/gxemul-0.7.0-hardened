+		/*  Mirror of the low 256 MB of RAM, at the 1 GB offset:  */
+		dev_ram_init(machine, 0x40000000ULL, 0x10000000ULL,
+		    DEV_RAM_MIRROR, 0x0, "ram_mirror");
